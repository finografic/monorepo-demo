{
  "name": "@finografic/monorepo-demo",
  "version": "0.0.1",
  "private": false,
  "description": "Portfolio monorepo demo with protected React/Vite apps for AI markdown streaming, Queensland TMR data visualisation, and dependency scan tooling, backed by a Hono/Auth.js API.",
  "keywords": [
    "typescript",
    "react",
    "vite",
    "hono",
    "portfolio"
  ],
  "homepage": "https://github.com/finografic/monorepo-demo",
  "bugs": "https://github.com/finografic/monorepo-demo/issues",
  "license": "MIT",
  "author": {
    "name": "Justin Rankin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://finografic.github.io/cv-justin-rankin"
  },
  "repository": "finografic/monorepo-demo.git",
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "moon run client:dev server:dev",
    "dev:aws": "pnpm --filter @workspace/client dev:aws",
    "dev:all": "pnpm kill:dev && moon run client:dev server:dev demo-ai-pipeline:dev demo-datavis:dev demo-xscan:dev",
    "dev:reset": "run-s reset",
    "dev:db:reset": "run-s db:reset",
    "start": "moon run client:start server:start",
    "build": "moon run :build",
    "build:pages": "moon run client:build-pages demo-ai-pipeline:build-pages demo-datavis:build-pages demo-xscan:build-pages",
    "·········· AWS_CLOUDFRONT": "··········································",
    "aws:frontend:build": "run-s aws:frontend:build:client aws:frontend:build:ai aws:frontend:build:datavis aws:frontend:build:xscan aws:frontend:assemble",
    "aws:frontend:build:client": "VITE_API_BASE_URL= VITE_BASE_PATH=/ pnpm --filter @workspace/client build:pages",
    "aws:frontend:build:ai": "VITE_AUTH_API_BASE_URL= VITE_API_BASE_URL= VITE_BASE_PATH=/demo-ai-pipeline/ pnpm --filter @workspace/demo-ai-pipeline build:pages",
    "aws:frontend:build:datavis": "VITE_AUTH_API_BASE_URL= VITE_API_BASE_URL= VITE_BASE_PATH=/demo-datavis/ pnpm --filter @workspace/demo-datavis build:pages",
    "aws:frontend:build:xscan": "VITE_AUTH_API_BASE_URL= VITE_API_BASE_URL= VITE_DEMO_XSCAN_API_BASE_URL=https://deps-xscan-api.onrender.com VITE_BASE_PATH=/demo-xscan/ pnpm --filter @workspace/demo-xscan build:pages",
    "aws:frontend:assemble": "rm -rf pages && mkdir -p pages/demo-ai-pipeline pages/demo-datavis pages/demo-xscan && cp -R apps/client/dist/. pages/ && cp -R apps/demo-ai-pipeline/dist/. pages/demo-ai-pipeline/ && cp -R apps/demo-datavis/dist/. pages/demo-datavis/ && cp -R apps/demo-xscan/dist/. pages/demo-xscan/ && cp pages/index.html pages/404.html",
    "aws:frontend:sync": "aws s3 sync pages s3://monorepo-demo-demo-frontend --delete --region ap-southeast-2",
    "aws:frontend:invalidate": "aws cloudfront create-invalidation --distribution-id ERCVOSB81GPS9 --paths '/*'",
    "aws:frontend:deploy": "run-s aws:frontend:build aws:frontend:sync aws:frontend:invalidate",
    "aws:frontend:outputs": "terraform -chdir=infra/terraform/environments/demo output",
    "aws:ec2:docker:build": "docker build --platform linux/amd64 --secret id=npm_token,env=NPM_TOKEN -f apps/server/Dockerfile.ec2-api -t monorepo-demo-server:ec2-api .",
    "aws:ec2:docker:run": "docker run --rm --platform linux/amd64 -p 4000:4000 --env-file .env.ec2-api.local -e PORT=4000 monorepo-demo-server:ec2-api",
    "test": "moon run :test",
    "·········· LINTING": "···················································",
    "lint": "moon run :lint",
    "lint:fix": "moon run :lint-fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "·········· TYPES": "·····················································",
    "typecheck": "moon run :typecheck",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --detach",
    "clean:dry": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --dry-run",
    "reset": "pnpm clean && pnpm install && pnpm syncpack:fix && pnpm build",
    "·········· DB": "··················································",
    "db:reset": "pnpm --filter @workspace/server db:reset",
    "db:studio": "pnpm --filter @workspace/server db:studio",
    "db:postgres:up": "docker compose up -d postgres",
    "db:postgres:down": "docker compose down",
    "db:postgres:logs": "docker compose logs -f postgres",
    "db:postgres:psql": "docker compose exec postgres psql -U monorepo_demo -d monorepo_demo",
    "·········· DEPS": "······················································",
    "deps:update": "pnpm update --latest --recursive && pnpm syncpack:fix",
    "verify:deps": "pnpm -r exec pnpm install --no-frozen-lockfile",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "syncpack:format": "syncpack format",
    "update:xscan-demo": "pnpm --filter @workspace/demo-xscan update:xscan-demo",
    "update:md-lint": "pnpm update @finografic/md-lint --latest",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest --recursive && pnpm update oxfmt --latest --recursive && pnpm update oxlint --latest --recursive",
    "update:project-scripts": "pnpm update @finografic/project-scripts --latest --recursive",
    "·········· UTILS": "·····················································",
    "kill:dev": "bash scripts/kill-dev.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@finografic/md-lint": "^0.16.6",
    "@finografic/oxc-config": "^2.8.2",
    "@finografic/project-scripts": "^1.5.4",
    "@moonrepo/cli": "^2.3.5",
    "@types/node": "^24.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "syncpack": "^15.3.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.16.0 <25",
    "pnpm": ">=10.20.0"
  },
  "packageManager": "pnpm@10.33.4",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
