{
  "name": "@finografic/monorepo-demo",
  "version": "0.0.1",
  "private": false,
  "description": "Full-stack portfolio monorepo — React/Vite + Hono/Auth.js API with typed RPC (Tanstack Query), deployed on Terraform-managed AWS (CloudFront, S3, EC2, RDS). Demos span AI markdown streaming, Queensland TMR data visualisation, and dependency security scanning.",
  "keywords": [
    "typescript",
    "react",
    "vite",
    "hono",
    "portfolio"
  ],
  "homepage": "https://github.com/finografic/monorepo-demo",
  "bugs": "https://github.com/finografic/monorepo-demo/issues",
  "license": "MIT",
  "author": {
    "name": "Justin Rankin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://finografic.github.io/cv-justin-rankin"
  },
  "repository": "finografic/monorepo-demo.git",
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "pnpm db:up && DATABASE_URL=${DATABASE_URL:-postgresql://monorepo_demo:monorepo_demo@localhost:5433/monorepo_demo} moon run client:dev server:dev",
    "dev:all": "pnpm kill:dev && pnpm db:up && DATABASE_URL=${DATABASE_URL:-postgresql://monorepo_demo:monorepo_demo@localhost:5433/monorepo_demo} moon run client:dev server:dev demo-ai-pipeline:dev demo-datavis:dev demo-xscan:dev",
    "dev:reset": "run-s reset",
    "dev:db:reset": "run-s db:reset",
    "start": "moon run client:start server:start",
    "build": "moon run :build",
    "build:pages": "moon run client:build-pages demo-ai-pipeline:build-pages demo-datavis:build-pages demo-xscan:build-pages",
    "·········· AWS_FRONTEND": "············································",
    "aws:frontend:build": "bash scripts/build-aws-frontend.sh",
    "aws:frontend:deploy": "pnpm aws:frontend:build && aws s3 sync pages s3://monorepo-demo-demo-frontend --delete --region ap-southeast-2 && aws cloudfront create-invalidation --distribution-id ERCVOSB81GPS9 --paths '/*'",
    "·········· AWS_INFRA": "················································",
    "aws:infra:outputs": "terraform -chdir=infra/terraform/environments/demo output",
    "aws:infra:plan": "terraform -chdir=infra/terraform/environments/demo plan -out=tfplan",
    "aws:infra:apply": "terraform -chdir=infra/terraform/environments/demo apply tfplan",
    "·········· AWS_EC2": "··················································",
    "aws:ec2:docker:build": "docker build --platform linux/amd64 --secret id=npm_token,env=NPM_TOKEN -f apps/server/Dockerfile.ec2-api -t monorepo-demo-server:ec2-api .",
    "aws:ec2:docker:run": "docker run --rm --platform linux/amd64 -p 4000:4000 --env-file .env.ec2-api.local -e PORT=4000 monorepo-demo-server:ec2-api",
    "test": "moon run :test",
    "·········· LINTING": "···················································",
    "lint": "moon run :lint",
    "lint:fix": "moon run :lint-fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "·········· TYPES": "·····················································",
    "typecheck": "moon run :typecheck",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --detach",
    "clean:dry": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --dry-run",
    "reset": "pnpm clean && pnpm install && pnpm syncpack:fix && pnpm build",
    "·········· DB": "··················································",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "pnpm --filter @workspace/server db:generate",
    "db:migrate": "pnpm --filter @workspace/server db:migrate",
    "db:psql": "docker compose exec postgres psql -U monorepo_demo -d monorepo_demo",
    "db:reset": "docker compose down -v && run-s db:setup",
    "db:seed": "pnpm --filter @workspace/server db:seed",
    "db:setup": "run-s db:up db:migrate db:seed",
    "db:studio": "pnpm --filter @workspace/server db:studio",
    "·········· DEPS": "······················································",
    "deps:update": "pnpm update --latest --recursive && pnpm syncpack:fix",
    "verify:deps": "pnpm -r exec pnpm install --no-frozen-lockfile",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "syncpack:format": "syncpack format",
    "update:xscan-demo": "pnpm --filter @workspace/demo-xscan update:xscan-demo",
    "update:md-lint": "pnpm update @finografic/md-lint --latest",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest --recursive && pnpm update oxfmt --latest --recursive && pnpm update oxlint --latest --recursive",
    "update:project-scripts": "pnpm update @finografic/project-scripts --latest --recursive",
    "·········· UTILS": "·····················································",
    "kill:dev": "bash scripts/kill-dev.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@finografic/md-lint": "^0.16.6",
    "@finografic/oxc-config": "^2.8.2",
    "@finografic/project-scripts": "^1.5.4",
    "@moonrepo/cli": "^2.3.5",
    "@types/node": "^24.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "syncpack": "^15.3.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.16.0 <25",
    "pnpm": ">=10.20.0"
  },
  "packageManager": "pnpm@10.33.4",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
