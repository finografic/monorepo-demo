{
  "name": "@finografic/monorepo-demo",
  "version": "0.0.1",
  "private": true,
  "description": "Full-stack pnpm monorepo starter — Vite 8 + React 19 + React Router v7 client; Hono + Drizzle ORM + Auth.js API server; shadcn + Tailwind 4 UI package; shared Valibot-validated env config; Moon task orchestration; oxlint toolchain; role-based access control and OpenAPI docs with Scalar UI.",
  "keywords": [
    "finografic",
    "monorepo",
    "moon",
    "pnpm",
    "starter",
    "typescript"
  ],
  "homepage": "https://github.com/finografic/monorepo-demo",
  "bugs": "https://github.com/finografic/monorepo-demo/issues",
  "license": "MIT",
  "author": {
    "name": "Justin Rankin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://finografic.github.io/cv-justin-rankin"
  },
  "repository": "finografic/monorepo-demo.git",
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "moon run client:dev server:dev",
    "dev:all": "pnpm kill:dev && moon run client:dev server:dev demo-ai-pipeline:dev demo-datavis:dev demo-xscan:dev",
    "dev:reset": "run-s reset",
    "dev:db:reset": "run-s db:reset",
    "start": "moon run client:start server:start",
    "build": "moon run :build",
    "build:pages": "moon run client:build-pages demo-ai-pipeline:build-pages demo-datavis:build-pages demo-xscan:build-pages",
    "test": "moon run :test",
    "·········· LINTING": "···················································",
    "lint": "moon run :lint",
    "lint:fix": "moon run :lint-fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "·········· TYPES": "·····················································",
    "typecheck": "moon run :typecheck",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --detach",
    "clean:dry": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --dry-run",
    "reset": "pnpm clean && pnpm install && pnpm syncpack:fix && pnpm build",
    "·········· DB:BATCH": "··················································",
    "db:reset": "pnpm db:drop && pnpm db:migrations:generate && pnpm db:migrations:run && pnpm db:migrations:auth && pnpm db:setup",
    "db:setup": "NODE_OPTIONS='--import tsx' db-setup -y",
    "·········· DB:UTILS": "··················································",
    "db:drop": "shx rm -rf data/*.sqlite.db data/migrations",
    "db:create": "pnpm --filter @workspace/server db:create",
    "db:studio": "pnpm --filter @workspace/server db:studio",
    "db:sqlite3:rebuild": "pnpm --package=@finografic/project-scripts dlx sqlite-rebuild",
    "·········· DB:DATA": "···················································",
    "db:migrations:generate": "pnpm --filter @workspace/server db:migrations:generate",
    "db:migrations:auth": "pnpm --filter @workspace/server db:migrations:seed user",
    "db:migrations:seed": "pnpm --filter @workspace/server db:migrations:seed",
    "db:migrations:run": "pnpm --filter @workspace/server db:migrations:run",
    "db:views:create": "pnpm --filter @workspace/server db:views:create",
    "db:views:create:single": "pnpm --filter @workspace/server db:views:create:single",
    "db:cleanup:short-keys": "pnpm --filter @workspace/server db:cleanup:short-keys",
    "·········· DEPS": "······················································",
    "deps:update": "pnpm update --latest --recursive && pnpm syncpack:fix",
    "verify:deps": "pnpm -r exec pnpm install --no-frozen-lockfile",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "syncpack:format": "syncpack format",
    "update:md-lint": "pnpm update @finografic/md-lint --latest",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest --recursive && pnpm update oxfmt --latest --recursive && pnpm update oxlint --latest --recursive",
    "update:project-scripts": "pnpm update @finografic/project-scripts --latest --recursive",
    "·········· UTILS": "·····················································",
    "kill:dev": "bash scripts/kill-dev.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@finografic/md-lint": "^0.16.6",
    "@finografic/oxc-config": "^2.8.2",
    "@finografic/project-scripts": "^1.5.4",
    "@moonrepo/cli": "^2.3.5",
    "@types/node": "^24.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "syncpack": "^15.3.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=10.20.0"
  },
  "packageManager": "pnpm@10.33.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
