{
  "name": "@workspace/demo-xscan",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json && vite build",
    "build:pages": "pnpm build",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --detach",
    "dev": "vite",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "start": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "update:xscan-demo": "pnpm update @finografic/deps-xscan-demo --latest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@finografic/deps-xscan-demo": "^0.1.1",
    "@workspace/shared": "workspace:*",
    "@workspace/ui": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.10"
  }
}
