{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@workspace/shared": ["../../packages/shared/src/index.ts"],
      "@workspace/shared/components": ["../../packages/shared/src/components/index.ts"],
      "@workspace/shared/components/*": ["../../packages/shared/src/components/*"],
      "@workspace/shared/assets/*": ["../../packages/shared/src/assets/*"],
      "@workspace/ui/globals.css": ["../../packages/ui/src/styles/globals.css"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "hooks/*": ["../../packages/ui/src/hooks/*"],
      "ui/*": ["../../packages/ui/src/components/*"],
      "utils": ["../../packages/ui/src/lib/utils"],
      "components/*": ["./src/components/*"],
      "pages/*": ["./src/pages/*"],
      "data/*": ["./src/data/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
