{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@workspace/ui/globals.css": ["../../packages/ui/src/styles/globals.css"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/shared": ["../../packages/shared/src/index.ts"],
      "hooks/*": ["../../packages/ui/src/hooks/*"],
      "ui/*": ["../../packages/ui/src/components/*"],
      "utils": ["../../packages/ui/src/lib/utils"],
      "lib/*": ["./src/lib/*"],
      "components/*": ["./src/components/*"],
      "pages/*": ["./src/pages/*"],
      "prompts/*": ["./src/prompts/*"],
      "fixtures/*": ["./src/fixtures/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
