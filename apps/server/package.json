{
  "name": "@workspace/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsx watch src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "·········· AWS_LAMBDA": "···············································",
    "lambda:build": "node ./scripts/build-lambda.mjs",
    "lambda:deploy": "pnpm lambda:build && sam build --template infra/aws-demo/template.yaml --build-dir infra/aws-demo/.aws-sam/build && sam deploy --template-file infra/aws-demo/.aws-sam/build/template.yaml --stack-name monorepo-demo-aws-api --resolve-s3 --capabilities CAPABILITY_IAM --region ap-southeast-2 --profile default --no-confirm-changeset --no-fail-on-empty-changeset",
    "lambda:delete": "sam delete --stack-name monorepo-demo-aws-api --region ap-southeast-2 --profile default --no-prompts",
    "lambda:logs": "sam logs -n AwsDemoFunction --stack-name monorepo-demo-aws-api --region ap-southeast-2 --profile default --tail",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "typecheck": "tsc --noEmit",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --detach",
    "·········· DB:BATCH": "··················································",
    "db:reset": "drizzle-kit push --config ./drizzle.config.ts --force && pnpm db:seed",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "·········· DB:UTILS": "··················································",
    "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
    "db:cleanup:short-keys": "tsx src/scripts/cleanup-short-keys.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.0",
    "@hono/auth-js": "^1.0.17",
    "@hono/node-server": "^1.19.0",
    "@hono/standard-validator": "^0.2.0",
    "@scalar/hono-api-reference": "^0.10.19",
    "@workspace/config": "workspace:*",
    "@workspace/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "drizzle-valibot": "^0.4.2",
    "hono": "^4.12.27",
    "hono-openapi": "^1.3.0",
    "hono-pino": "^0.10.3",
    "http-status-codes": "^2.3.0",
    "openai": "^6.45.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@clack/prompts": "^0.10.0",
    "@types/node": "^24.12.0",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.27.7",
    "tsdown": "^0.21.10",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
