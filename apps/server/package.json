{
  "name": "@workspace/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsx watch src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "·········· AWS_LAMBDA": "···············································",
    "lambda:build": "node ./scripts/build-lambda.mjs",
    "lambda:deploy": "pnpm lambda:build && sam build --template infra/aws-demo/template.yaml --build-dir infra/aws-demo/.aws-sam/build && sam deploy --template-file infra/aws-demo/.aws-sam/build/template.yaml --stack-name monorepo-demo-aws-api --resolve-s3 --capabilities CAPABILITY_IAM --region ap-southeast-2 --profile default --no-confirm-changeset --no-fail-on-empty-changeset",
    "lambda:delete": "sam delete --stack-name monorepo-demo-aws-api --region ap-southeast-2 --profile default --no-prompts",
    "lambda:logs": "sam logs -n AwsDemoFunction --stack-name monorepo-demo-aws-api --region ap-southeast-2 --profile default --tail",
    "·········· AWS_APP_RUNNER": "··········································",
    "app-runner:docker:build": "docker build --platform linux/amd64 --secret id=npm_token,env=NPM_TOKEN -f Dockerfile.app-runner -t monorepo-demo-server:app-runner ../..",
    "app-runner:docker:run": "docker run --rm -p 4000:4000 --env-file ../../.env.app-runner.local -e PORT=4000 monorepo-demo-server:app-runner",
    "·········· RENDER": "·····················································",
    "render:start": "NODE_ENV=production pnpm render:db:bootstrap && NODE_ENV=production pnpm start",
    "render:db:bootstrap": "pnpm render:db:create && pnpm render:db:seed",
    "render:db:create": "drizzle-kit push --config ./drizzle.config.ts --force",
    "render:db:seed": "tsx src/db/utils/seed.ts user && tsx src/db/utils/seed.ts supported_languages && tsx src/db/utils/seed.ts translations_ui && tsx src/db/utils/seed.ts translations_app && tsx src/db/utils/seed.ts translations_admin",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "typecheck": "tsc --noEmit",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --detach",
    "·········· DB:BATCH": "··················································",
    "db:reset": "pnpm db:drop && pnpm db:migrations:generate && pnpm db:migrations:run && pnpm db:migrations:auth && pnpm db:setup",
    "db:setup": "NODE_OPTIONS='--import tsx' db-setup -y",
    "·········· DB:UTILS": "··················································",
    "db:drop": "rm -rf ../../data/*.sqlite.db ../../data/migrations",
    "db:create": "drizzle-kit push --config ./drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
    "db:postgres:generate": "drizzle-kit generate --config ./drizzle.postgres.config.ts",
    "db:postgres:migrate": "drizzle-kit migrate --config ./drizzle.postgres.config.ts",
    "db:postgres:seed": "DATABASE_URL=${DATABASE_URL:-postgresql://monorepo_demo:monorepo_demo@localhost:5433/monorepo_demo} tsx src/db/seed-postgres.ts",
    "db:postgres:studio": "drizzle-kit studio --config ./drizzle.postgres.config.ts",
    "db:migrations:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrations:auth": "tsx src/db/utils/seed.ts user",
    "db:migrations:seed": "tsx src/db/utils/seed.ts",
    "db:migrations:run": "tsx src/db/utils/migrate.ts",
    "db:views:create": "tsx src/db/utils/create-view.ts all",
    "db:views:create:single": "tsx src/db/utils/create-view.ts",
    "db:cleanup:short-keys": "tsx src/scripts/cleanup-short-keys.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.0",
    "@hono/auth-js": "^1.0.17",
    "@hono/node-server": "^1.19.0",
    "@hono/standard-validator": "^0.2.0",
    "@scalar/hono-api-reference": "^0.10.19",
    "@workspace/config": "workspace:*",
    "@workspace/shared": "workspace:*",
    "better-sqlite3": "^11.9.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-valibot": "^0.4.2",
    "hono": "^4.12.27",
    "hono-openapi": "^1.3.0",
    "hono-pino": "^0.10.3",
    "http-status-codes": "^2.3.0",
    "openai": "^6.45.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@clack/prompts": "^0.10.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.27.7",
    "tsdown": "^0.21.10",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
