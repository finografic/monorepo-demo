# Environment Configuration Example
# Copy to .env.development and fill in values.

# GitHub Token (for @finografic scoped packages from GitHub Packages)
NPM_TOKEN=

# Application Environment
NODE_ENV=development

# API Server Configuration
API_PROTOCOL=http
API_HOST=localhost
API_PORT=4040
API_BASE_PATH=/api

# Client Configuration
CLIENT_PROTOCOL=http
CLIENT_HOST=localhost
CLIENT_PORT=3000
VITE_API_BASE_URL=http://localhost:4040
VITE_AUTH_API_BASE_URL=http://localhost:4040
VITE_AWS_FRONTEND_URL=https://d2h3ihm2ddi3lx.cloudfront.net
VITE_DEMO_AI_PIPELINE_URL=http://localhost:3001
VITE_DEMO_DATAVIS_URL=http://localhost:3002
VITE_DEMO_XSCAN_URL=http://localhost:3003

# Database Configuration
DATABASE_URL=postgresql://monorepo_demo:monorepo_demo@localhost:5433/monorepo_demo

# Authentication
AUTH_SECRET=change-me-to-a-32-char-random-string
AUTH_URL=http://localhost:4040/api/auth
AUTH_COOKIE_PREFIX=monorepo-demo
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
TOKEN_COOKIE_SUFFIX=session_token
DATA_COOKIE_SUFFIX=session_data
# Set to false in dev to keep JWT sessions alive across server restarts
AUTH_INVALIDATE_JWT_ON_SERVER_BOOT=false
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# LLM providers
# LLM_MODE: "local" = LM Studio, "hosted" = OpenCode Go
LLM_MODE=local

ANTHROPIC_API_KEY=

# Local live mode (LM Studio)
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=google/gemma-4-26b-a4b

# Hosted live mode (OpenCode Go) — set LLM_MODE=hosted to activate
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=qwen3.7-plus
