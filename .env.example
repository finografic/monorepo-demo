# Environment Configuration Example
# Copy to .env.development and fill in values.

# GitHub Token (for @finografic scoped packages from GitHub Packages)
NPM_TOKEN=

# Application Environment
NODE_ENV=development

# API Server Configuration
API_PROTOCOL=http
API_HOST=localhost
API_PORT=4040
API_BASE_PATH=/api

# Client Configuration
CLIENT_PROTOCOL=http
CLIENT_HOST=localhost
CLIENT_PORT=3000

# Database Configuration
DB_HOST=localhost
DB_USER=admin
DB_PASS=
DB_NAME=development.sqlite.db
DB_DIALECT=sqlite
DB_PORT=0

# Authentication
AUTH_SECRET=change-me-to-a-32-char-random-string
AUTH_URL=http://localhost:4040
AUTH_COOKIE_PREFIX=monorepo-starter
TOKEN_COOKIE_SUFFIX=session_token
DATA_COOKIE_SUFFIX=session_data
# Set to false in dev to keep JWT sessions alive across server restarts
AUTH_INVALIDATE_JWT_ON_SERVER_BOOT=false

# LLM providers
# LLM_MODE: "local" = LM Studio, "hosted" = OpenCode Go
LLM_MODE=local

ANTHROPIC_API_KEY=

# Local live mode (LM Studio)
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=google/gemma-4-26b-a4b

# Hosted live mode (OpenCode Go) — set LLM_MODE=hosted to activate
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=glm-5.2
