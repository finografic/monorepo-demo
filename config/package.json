{
  "name": "@workspace/config",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "import": "./src/env.ts"
    },
    "./paths": {
      "types": "./src/paths.ts",
      "import": "./src/paths.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "lint": "oxlint -c ../oxlint.config.ts",
    "lint:fix": "oxlint -c ../oxlint.config.ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@finografic/project-scripts": "^1.5.4",
    "@types/node": "^24.12.0",
    "typescript": "^6.0.3"
  }
}
